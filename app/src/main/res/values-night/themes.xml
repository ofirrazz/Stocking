<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.StockSocial.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_mark</item>
        <item name="postSplashScreenTheme">@style/Theme.StockSocial</item>
    </style>

    <!-- אותה ערכת נושא כהה (עקביות עם הפיגמה) -->
    <style name="Theme.StockSocial" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary_gold</item>
        <item name="colorOnPrimary">@color/background</item>
        <item name="colorPrimaryContainer">@color/surface_card</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>
        <item name="colorSecondary">@color/silver</item>
        <item name="colorOnSecondary">@color/background</item>
        <item name="colorTertiary">@color/accent_gold</item>
        <item name="colorOnTertiary">@color/background</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_muted</item>
        <item name="colorOutline">@color/border</item>
        <item name="colorOutlineVariant">@color/border</item>
        <item name="colorError">@color/destructive</item>
        <item name="colorOnError">@color/text_primary</item>
        <item name="colorControlActivated">@color/primary_gold</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
