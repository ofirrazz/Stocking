<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.StockSocial" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary_gold</item>
        <item name="colorOnPrimary">@color/background</item>
        <item name="colorSecondary">@color/accent_gold</item>
        <item name="colorOnSecondary">@color/background</item>
        <item name="colorTertiary">@color/silver</item>
        <item name="colorOnTertiary">@color/background</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/border</item>
        <item name="colorOnSurfaceVariant">@color/text_muted</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorError">@color/destructive_red</item>
        <item name="colorOnError">@color/white</item>
        <item name="colorOutline">@color/border</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
        <item name="colorControlActivated">@color/primary_gold</item>
        <item name="colorControlHighlight">@color/ripple_gold</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.StockSocial.MaterialAlertDialog</item>
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.StockSocial.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.StockSocial.DisplayMedium</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.StockSocial.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.StockSocial.HeadlineMedium</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.StockSocial.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.StockSocial.TitleMedium</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.StockSocial.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.StockSocial.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.StockSocial.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.StockSocial.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.StockSocial.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.StockSocial.LabelSmall</item>
    </style>

    <!-- Alias for design docs / templates that reference SocialStock -->
    <style name="Theme.SocialStock" parent="Theme.StockSocial" />

    <style name="ThemeOverlay.StockSocial.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="backgroundTint">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_muted</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.Material3.Button.TextButton.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.Material3.Button.TextButton.Dialog</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>
